# Runtime mode for the backend. Use production on Render.
NODE_ENV=development

# HTTP port for the backend. Render usually injects PORT automatically.
PORT=4000

# Public frontend origin allowed by backend CORS and cookies.
CLIENT_URL=http://localhost:5173

# PostgreSQL connection string used by Prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mwda

# Secret used to sign 7-day JWT auth cookies. Must be at least 32 bytes.
JWT_SECRET=replace-with-a-long-random-secret

# Backend log level used by Pino.
LOG_LEVEL=info

# Supabase project URL, for example https://your-project.supabase.co. Do not include /rest/v1.
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key used only by the backend for Storage writes.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Supabase Storage bucket for uploaded documents.
SUPABASE_STORAGE_BUCKET=documents

# Google AI Studio API key used by Gemini embeddings and chat generation.
GEMINI_API_KEY=replace-with-gemini-api-key

# Gemini embedding model name. text-embedding-004 was shut down 2026-01-14; use gemini-embedding-001.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Gemini chat model name.
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Maximum requests per rate-limit window.
RATE_LIMIT_MAX_REQUESTS=120

# Rate-limit window duration in milliseconds.
RATE_LIMIT_WINDOW_MS=60000
