{
  "name": "@mwda/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts --max-warnings=0 --config ../../eslint.config.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init"
  },
  "dependencies": {
    "@mwda/shared": "file:../../packages/shared",
    "better-auth": "^1.2.4",
    "cors": "^2.8.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "helmet": "^8.1.0",
    "pino": "^9.1.0",
    "pino-http": "^10.0.0",
    "prisma": "^6.1.0",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
