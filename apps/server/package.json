{
  "name": "@mwda/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "lint": "eslint src --ext .ts --max-warnings=0 --config ../../eslint.config.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "test:db": "tsx scripts/test-db-connection.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@mwda/shared": "file:../../packages/shared",
    "@prisma/client": "^6.1.0",
    "@supabase/supabase-js": "^2.110.0",
    "@types/pg": "^8.20.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "pino": "^9.1.0",
    "pino-http": "^10.0.0",
    "prisma": "^6.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.2.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
